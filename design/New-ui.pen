                      "name": "InfoText",
                      "fill": "$on-surface",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "データフェッチは可能な限り親のServer Componentで行い、結果をpropsとしてClient Componentに渡す設計を心がけましょう。これにより不要なクライアントサイドのウォーターフォールリクエストを防ぐことができます。",
                      "lineHeight": 1.75,
                      "fontFamily": "$font-inter",
                      "fontSize": 16.8,
                      "fontWeight": "normal",
                      "letterSpacing": 0.2
                    }
                  ]
