                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "インタラクティブな要素（useState, onClickなど）が必要な場合のみ、ファイルの先頭で use client ディレクティブを宣言し、Client Componentとします。",
                  "lineHeight": 1.75,
                  "fontFamily": "$font-inter",
                  "fontSize": 16.8,
                  "fontWeight": "normal",
                  "letterSpacing": 0.2
                },
                {
                  "id": "NSDJb",
