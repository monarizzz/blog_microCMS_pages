                  "x": 0,
                  "y": 607
                },
                {
                  "type": "text",
                  "id": "X5xDp",
                  "name": "P4",
                  "fill": "$on-surface",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "重要なのは、「ツリーの葉」に向かってのみClient Componentsを配置することです。Server ComponentsをClient Componentsの直接の子としてインポートすることはできませんが、children propとして渡すことは可能です。",
                  "lineHeight": 1.75,
                  "fontFamily": "$font-inter",
                  "fontSize": 16.8,
                  "fontWeight": "normal",
                  "letterSpacing": 0.2
                },
                {
                  "id": "u54AqV",
                  "type": "ref",
                  "ref": "Y1rfsy",
                  "x": 0,
                  "y": 911
                },
                {
                  "type": "frame",
